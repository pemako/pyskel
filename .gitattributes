# Force LF line endings on text files — critical for shell scripts,
# which break under CRLF on Linux/macOS.
* text=auto eol=lf

# Explicit text classification for the things that matter most.
*.sh   text eol=lf
*.bash text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.cfg  text eol=lf
*.proto   text eol=lf
*.thrift  text eol=lf

# Binary — never normalize line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.tar.gz binary
*.pyc   binary
